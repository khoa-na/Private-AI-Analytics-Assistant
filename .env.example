OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_API_KEY=<DeepSeek API key>
OPENAI_MODEL=deepseek-v4-flash
# Optional override; review is blind even when OPENAI_MODEL is reused.
# OPENAI_REVIEW_MODEL=<review model>
ACTIVE_DATABASE_PATH=data/active/database.sqlite
SQLITE_CACHE_KIB=65536
SQLITE_MMAP_BYTES=1073741824

OPENAI_REASONING_EFFORT=low
# Optional stage overrides for benchmarking:
# OPENAI_SQL_REASONING_EFFORT=low
# OPENAI_ANALYSIS_REASONING_EFFORT=medium
OPENAI_ANALYSIS_MAX_TOKENS=2400
OPENAI_SQL_MAX_TOKENS=4096
OPENAI_REVIEW_MAX_TOKENS=2000
