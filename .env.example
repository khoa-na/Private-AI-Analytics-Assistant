OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_API_KEY=<DeepSeek API key>
OPENAI_MODEL=deepseek-v4-flash
LLM_AUTH_MODE=bearer
LLM_JSON_MODE=native
LLM_REASONING_TRANSPORT=deepseek
LLM_THINKING=disabled
OPENAI_REASONING_EFFORT=low
LLM_SEND_TEMPERATURE=true
LLM_REQUEST_TIMEOUT_MS=60000
LLM_MAX_RETRIES=1

# Optional override; review is blind even when OPENAI_MODEL is reused.
# OPENAI_REVIEW_MODEL=<review model>
ACTIVE_DATABASE_PATH=data/active/database.duckdb
DUCKDB_THREADS=4
DUCKDB_IMPORT_THREADS=8
DUCKDB_MEMORY_LIMIT=8GB

# Optional stage overrides for benchmarking:
# OPENAI_SQL_REASONING_EFFORT=low
# OPENAI_ANALYSIS_REASONING_EFFORT=medium
OPENAI_ANALYSIS_MAX_TOKENS=2400
OPENAI_SQL_MAX_TOKENS=4096
# Only used for one-query steps after a large plan is decomposed.
OPENAI_STEP_MAX_TOKENS=6144
OPENAI_REVIEW_MAX_TOKENS=2000
# Optional compact multi-query decomposition fallback.
# OPENAI_PLAN_MAX_TOKENS=1200
